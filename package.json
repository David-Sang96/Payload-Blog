{
    "name": "",
    "version": "1.0.0",
    "description": "A blank template to get started with Payload 3.0",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
        "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
        "payload:migrate:create": "payload migrate:create",
        "payload:migrate": "payload migrate",
        "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
        "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
        "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
        "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
        "format": "prettier . --write",
        "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
        "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
        "seed": "tsx -r dotenv/config src/scripts/seed/script.ts",
        "nuke": "psql -U postgres -d payload_next_blog -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && pnpm payload migrate:fresh && pnpm seed",
        "reset:articles": "psql -U postgres -d payload_next_blog -c \"TRUNCATE TABLE articles RESTART IDENTITY CASCADE;\"",
        "reset:articles:seed": "psql -U postgres -d payload_next_blog -c \"TRUNCATE TABLE articles RESTART IDENTITY CASCADE;\" && pnpm seed",
        "reset:content:seed": "psql -U postgres -d payload_next_blog -c \"TRUNCATE TABLE article_authors, articles, media RESTART IDENTITY CASCADE;\" && pnpm seed"
    },
    "dependencies": {
        "@payloadcms/db-postgres": "3.83.0",
        "@payloadcms/next": "3.83.0",
        "@payloadcms/richtext-lexical": "3.83.0",
        "@payloadcms/ui": "3.83.0",
        "@plaiceholder/next": "^3.0.0",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@tailwindcss/postcss": "^4.2.4",
        "cross-env": "^7.0.3",
        "dotenv": "16.4.7",
        "drizzle-orm": "^0.45.2",
        "graphql": "^16.8.1",
        "next": "16.2.3",
        "next-themes": "^0.4.6",
        "payload": "3.83.0",
        "plaiceholder": "^3.0.0",
        "postcss": "^8.5.10",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "sharp": "0.34.2",
        "tailwindcss": "^4.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.4.0",
        "@playwright/test": "1.58.2",
        "@tailwindcss/typography": "^0.5.19",
        "@testing-library/react": "16.3.0",
        "@types/node": "22.19.9",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "4.5.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.16.0",
        "eslint-config-next": "16.2.3",
        "jsdom": "28.0.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "0.0.0-insiders.f7d2598",
        "tsx": "4.21.0",
        "typescript": "5.7.3",
        "vite-tsconfig-paths": "6.0.5",
        "vitest": "4.0.18"
    },
    "engines": {
        "node": "^18.20.2 || >=20.9.0",
        "pnpm": "^9 || ^10"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "sharp",
            "esbuild",
            "unrs-resolver"
        ]
    }
}
